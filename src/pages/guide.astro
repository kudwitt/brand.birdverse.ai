  <!-- JavaScript Controls -->
  <script is:inline>
    // Theme Toggle Functionality
    function toggleTheme() {
      const html = document.documentElement;
      const themeText = document.getElementById('theme-text');
      const themeIcon = document.getElementById('theme-icon');
      
      if (html.getAttribute('data-theme') === 'dark') {
        html.setAttribute('data-theme', 'light');
        themeText.innerText = 'Light Cockpit';
        themeIcon.innerText = '☀️';
      } else {
        html.setAttribute('data-theme', 'dark');
        themeText.innerText = 'Dark Cockpit';
        themeIcon.innerText = '🌙';
      }
      // Re-trigger playground to update outlines and stroke definitions
      updateLogoPlayground();
      
      // Update Tagline mock styling
      const activeTabBtn = document.querySelector('.tagline-tab-btn.active');
      if (activeTabBtn) {
        const activeTabId = activeTabBtn.id.replace('tab-', '');
        toggleTaglineMock(activeTabId);
      }
    }

    // Smooth scroll to section and manage active sidebar state
    function scrollToSection(id) {
      const el = document.getElementById(id);
      if (el) {
        el.scrollIntoView({ behavior: 'smooth' });
      }
      
      // Update active nav rail
      document.querySelectorAll('.nav-item').forEach(item => {
        item.classList.remove('active');
        if (item.getAttribute('data-section') === id) {
          item.classList.add('active');
        }
      });
    }

    // Scroll Spy for Side Navigation
    window.addEventListener('scroll', () => {
      const sections = document.querySelectorAll('section');
      const scrollPos = window.scrollY + 120;
      
      sections.forEach(section => {
        if (scrollPos >= section.offsetTop && scrollPos < (section.offsetTop + section.offsetHeight)) {
          document.querySelectorAll('.nav-item').forEach(item => {
            item.classList.remove('active');
            if (item.getAttribute('data-section') === section.id) {
              item.classList.add('active');
            }
          });
        }
      });
    });

    // Logo Sandbox Interactive Functions
    let currentCanvasBg = '#040a1b';
    
    function updateLogoCanvasColor(color, element) {
      // Swatch selection active state
      document.querySelectorAll('.swatch').forEach(s => s.classList.remove('active'));
      element.classList.add('active');
      
      // Update Canvas Color
      const canvas = document.getElementById('canvas-preview');
      canvas.style.backgroundColor = color;
      currentCanvasBg = color;
      
      document.getElementById('canvas-label').innerText = `Canvas Background: ${color.toUpperCase()}`;
      
      // Update logo SVG fill/stroke details
      updateLogoPlayground();
    }
    
    function updateLogoPlayground() {
      const config = document.querySelector('input[name="logo-config"]:checked').value;
      const birdSvg = document.getElementById('logo-sandbox-svg');
      const wordmark = document.getElementById('logo-sandbox-text');
      const birdPath = document.getElementById('logo-bird-path');
      
      // Configuration Visibility toggles
      if (config === 'combined') {
        birdSvg.style.display = 'block';
        wordmark.style.display = 'block';
      } else if (config === 'icon') {
        birdSvg.style.display = 'block';
        wordmark.style.display = 'none';
      } else if (config === 'wordmark') {
        birdSvg.style.display = 'none';
        wordmark.style.display = 'block';
      }
      
      // Sandbox light/dark outline rules
      const isLightBg = (currentCanvasBg === '#ffffff' || currentCanvasBg === '#f1f5f9');
      
      if (isLightBg) {
        // Light Background: Outlined logo
        birdPath.setAttribute('fill', '#E0F2FE');
        birdPath.setAttribute('stroke', '#0F172A');
        birdPath.setAttribute('stroke-width', '12');
        // Wordmark Suffix color mapping
        document.documentElement.style.setProperty('--logo-sandbox-ai-color', '#0F172A');
      } else {
        // Dark Background: Solid logo fill
        birdPath.setAttribute('fill', '#E0F2FE');
        birdPath.removeAttribute('stroke');
        birdPath.removeAttribute('stroke-width');
        // Wordmark Suffix color mapping
        document.documentElement.style.setProperty('--logo-sandbox-ai-color', '#ffffff');
      }
      
      // Update code output snippet
      updateCodeOutputSnippet(config, isLightBg);
    }
    
    function updateCodeOutputSnippet(config, isLightBg) {
      const snippetBox = document.getElementById('code-snippet-box');
      let strokeAttr = isLightBg ? ' stroke="#0F172A" stroke-width="12"' : '';
      
      if (config === 'combined') {
        snippetBox.innerText = `<div class="logo-brand">\n` +
          `  <svg viewBox="0 0 512 512" fill="none" width="32" height="32">\n` +
          `    <path d="M215.091 262..." fill="#E0F2FE"${strokeAttr}/>\n` +
          `  </svg>\n` +
          `  <span class="wordmark">\n` +
          `    <span style="color: #FFA028;">Birdverse</span>\n` +
          `  </span>\n` +
          `</div>`;
      } else if (config === 'icon') {
        snippetBox.innerText = `<svg viewBox="0 0 512 512" fill="none" width="80" height="80">\n` +
          `  <path d="M215.091 262.074C225.098 242.154 233.069 222.999 238 205C128 150 36 108 18 92C100 72 240 82 318 125C362 95 396 63 410 50C400 78 348 125 310 178C387.357 273.608 453.711 349.930 463.471 371.947C421.845 360.891 320.138 335.704 215.091 262.074Z" fill="#E0F2FE"${strokeAttr}/>\n` +
          `</svg>`;
      } else {
        snippetBox.innerText = `<span class="wordmark">\n` +
          `  <span style="color: #FFA028;">Birdverse</span>\n` +
          `</span>`;
      }
    }
    
    function copyCodeSnippet() {
      const snippet = document.getElementById('code-snippet-box').innerText;
      navigator.clipboard.writeText(snippet).then(() => {
        showToast('Code snippet copied!');
      });
    }
    
    function copySnippet(id) {
      const snippet = document.getElementById(id).innerText;
      navigator.clipboard.writeText(snippet).then(() => {
        showToast('Code copied to clipboard!');
      });
    }
    
    // Copy color hex to clipboard
    function copyColorToken(hex, name) {
      navigator.clipboard.writeText(hex).then(() => {
        showToast(`${name} (${hex}) copied to clipboard!`);
      });
    }
    
    // Show Toast Notification
    function showToast(text) {
      const toast = document.getElementById('toast-notif');
      toast.innerText = text;
      toast.classList.add('show');
      setTimeout(() => {
        toast.classList.remove('show');
      }, 2000);
    }
    
    // Tagline context preview simulator
    function toggleTaglineMock(tab) {
      // Manage active tabs state
      document.querySelectorAll('.tagline-tab-btn').forEach(btn => btn.classList.remove('active'));
      document.getElementById(`tab-${tab}`).classList.add('active');
      
      const windowPreview = document.getElementById('tagline-preview-window');
      const isLightTheme = document.documentElement.getAttribute('data-theme') === 'light';
      
      // Theme colors for mock windows
      const mockBg = isLightTheme ? '#ffffff' : '#040a1b';
      const mockText = isLightTheme ? '#0f172a' : '#f7f9fb';
      const mockTextSec = isLightTheme ? '#475569' : '#c1cbd4';
      const mockBorder = isLightTheme ? 'rgba(15, 23, 42, 0.08)' : 'rgba(255,255,255,0.05)';
      const mockHeaderBg = isLightTheme ? 'rgba(241, 245, 249, 0.9)' : 'rgba(8, 20, 49, 0.8)';
      
      windowPreview.style.backgroundColor = mockBg;
      windowPreview.style.color = mockText;
      windowPreview.style.borderColor = mockBorder;
      
      if (tab === 'login') {
        // Outline logo in light mode
        const strokeAttr = isLightTheme ? ' stroke="#0F172A" stroke-width="12"' : '';
        windowPreview.innerHTML = 
          `<div class="mock-hero">\n` +
          `  <svg viewBox="0 0 512 512" fill="none" width="50" height="50" style="margin-bottom: 10px;">\n` +
          `    <path d="M215.091 262.074C225.098 242.154 233.069 222.999 238 205C128 150 36 108 18 92C100 72 240 82 318 125C362 95 396 63 410 50C400 78 348 125 310 178C387.357 273.608 453.711 349.930 463.471 371.947C421.845 360.891 320.138 335.704 215.091 262.074Z" fill="#E0F2FE"${strokeAttr}/>\n` +
          `  </svg>\n` +
          `  <div class="mock-hero-title" style="color: #FFA028; margin-bottom: 4px;">Birdverse</div>\n` +
          `  <div class="mock-hero-tagline" style="color: ${mockTextSec}; margin-bottom: 4px;">The Terminal for the Aviation Industry</div>\n` +
          `  <div style="font-family: var(--font-technical); font-size: 0.85rem; color: var(--brand-orange); font-weight: 600; margin-bottom: 12px;">birdverse.ai</div>\n` +
          `  <div class="tagline-badge">TAGLINE & URL SHOWN</div>\n` +
          `</div>`;
      } else if (tab === 'landing') {
        const strokeAttr = isLightTheme ? ' stroke="#0F172A" stroke-width="12"' : '';
        windowPreview.innerHTML = 
          `<div class="mock-header" style="background: ${mockHeaderBg}; border-color: ${mockBorder};">\n` +
          `  <div class="mock-logo">\n` +
          `    <svg viewBox="0 0 512 512" fill="none" width="18" height="18">\n` +
          `      <path d="M215.091 262.074C225.098 242.154 233.069 222.999 238 205C128 150 36 108 18 92C100 72 240 82 318 125C362 95 396 63 410 50C400 78 348 125 310 178C387.357 273.608 453.711 349.930 463.471 371.947C421.845 360.891 320.138 335.704 215.091 262.074Z" fill="#E0F2FE"${strokeAttr}/>\n` +
          `    </svg>\n` +
          `    <span style="color: ${mockText}; font-family: Montserrat, sans-serif; font-weight:700; color:#FFA028;">Birdverse</span>\n` +
          `  </div>\n` +
          `  <div class="mock-links" style="background: ${isLightTheme ? 'rgba(0,0,0,0.1)' : 'rgba(255,255,255,0.1)'};"></div>\n` +
          `</div>\n` +
          `<div class="mock-hero" style="justify-content: flex-start; padding-top: 10px;">\n` +
          `  <div class="mock-hero-title" style="font-size: 1.8rem; color: #FFA028; margin-bottom: 4px;">Birdverse</div>\n` +
          `  <div class="mock-hero-tagline" style="color: ${mockTextSec}; margin-bottom: 4px;">The Terminal for the Aviation Industry</div>\n` +
          `  <div style="font-family: var(--font-technical); font-size: 0.85rem; color: var(--brand-orange); font-weight: 600; margin-bottom: 8px;">birdverse.ai</div>\n` +
          `  <div class="tagline-badge">TAGLINE & URL SHOWN</div>\n` +
          `</div>`;
      } else {
        const strokeAttr = isLightTheme ? ' stroke="#0F172A" stroke-width="12"' : '';
        const itemBg = isLightTheme ? 'rgba(0,0,0,0.05)' : 'rgba(255,255,255,0.05)';
        windowPreview.innerHTML = 
          `<div class="mock-header" style="margin-bottom: 8px; background: ${mockHeaderBg}; border-color: ${mockBorder};">\n` +
          `  <div class="mock-logo">\n` +
          `    <svg viewBox="0 0 512 512" fill="none" width="18" height="18">\n` +
          `      <path d="M215.091 262.074C225.098 242.154 233.069 222.999 238 205C128 150 36 108 18 92C100 72 240 82 318 125C362 95 396 63 410 50C400 78 348 125 310 178C387.357 273.608 453.711 349.930 463.471 371.947C421.845 360.891 320.138 335.704 215.091 262.074Z" fill="#E0F2FE"${strokeAttr}/>\n` +
          `    </svg>\n` +
          `    <span style="color: ${mockText}; font-family: Montserrat, sans-serif; font-weight:700; color:#FFA028;">Birdverse</span>\n` +
          `  </div>\n` +
          `  <div style="font-size: 0.7rem; color: #ef4444; border: 1px solid #ef4444; padding: 2px 6px; border-radius: 4px; font-weight: bold; background: rgba(239, 68, 68, 0.05);">TAGLINE HIDDEN</div>\n` +
          `</div>\n` +
          `<div class="mock-grid">\n` +
          `  <div class="mock-sidebar" style="background: ${isLightTheme ? 'rgba(0,0,0,0.015)' : 'rgba(255,255,255,0.02)'}; border-color: ${mockBorder};">\n` +
          `    <div class="mock-sidebar-item active"></div>\n` +
          `    <div class="mock-sidebar-item" style="background: ${itemBg};"></div>\n` +
          `    <div class="mock-sidebar-item" style="background: ${itemBg};"></div>\n` +
          `  </div>\n` +
          `  <div class="mock-content" style="background: ${isLightTheme ? 'rgba(0,0,0,0.005)' : 'rgba(255,255,255,0.01)'}; border-color: ${mockBorder};">\n` +
          `    <div class="mock-row" style="width: 80%; background: ${itemBg};"></div>\n` +
          `    <div class="mock-row" style="width: 95%; background: ${itemBg};"></div>\n` +
          `    <div class="mock-row" style="width: 40%; background: ${itemBg};"></div>\n` +
          `  </div>\n` +
          `</div>`;
      }
    }
    
    // Initialize playground outputs on load
    updateLogoPlayground();
    toggleTaglineMock('login');
  </script>
</body>
</html>

---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Birdverse — Talk to Us</title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Montserrat:wght@700;800&family=Outfit:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  
  <style>
    :root {
      /* Typography */
      --font-primary: 'Montserrat', sans-serif;
      --font-secondary: 'Outfit', sans-serif;
      --font-body: 'Inter', sans-serif;
      --font-technical: 'JetBrains Mono', monospace;

      /* Color Tokens (Cockpit Standard) */
      --dark-bg: #081431;            /* Aether Blue */
      --card-bg: #101e3e;            /* Deep Cockpit Surface */
      --card-bg-hover: #17284f;      /* Sleek Hover Blue */
      
      --brand-orange: #ffa028;       /* Terminal Orange */
      --brand-arctic-ice: #e0f2fe;   /* Arctic Ice */
      --brand-deep-slate: #0f172a;   /* Deep Slate */
      
      --gray-velocity: #c1cbd4;      /* Velocity Gray */
      --white-horizon: #f7f9fb;      /* Horizon White */

      /* Avionics Status Alerts */
      --success: hsl(145, 80%, 45%);   /* Avionics Green */
      --caution: hsl(40, 100%, 50%);   /* Aviation Amber */
      --alert: hsl(350, 100%, 45%);     /* Master Warning Red */

      --border-color: rgba(224, 242, 254, 0.08);
      --border-glow: rgba(255, 160, 40, 0.25);
      
      --transition-normal: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      --transition-fast: all 0.15s ease;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html, body {
      max-width: 100vw;
      overflow-x: hidden;
      width: 100%;
    }

    body {
      background-color: var(--dark-bg);
      color: var(--white-horizon);
      font-family: var(--font-body);
      line-height: 1.6;
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    /* Background Gradients */
    body::before {
      content: '';
      position: absolute;
      top: -10%;
      left: -15%;
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, rgba(255, 160, 40, 0.04) 0%, rgba(8, 20, 49, 0) 70%);
      z-index: -1;
      pointer-events: none;
    }

    body::after {
      content: '';
      position: absolute;
      bottom: -10%;
      right: -10%;
      width: 700px;
      height: 700px;
      background: radial-gradient(circle, rgba(224, 242, 254, 0.03) 0%, rgba(8, 20, 49, 0) 70%);
      z-index: -1;
      pointer-events: none;
    }

    /* Fixed Navigation Bar */
    nav {
      width: 100%;
      height: 75px;
      background: rgba(8, 20, 49, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-color);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 4rem;
      z-index: 1000;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .nav-logo-svg {
      width: 26px;
      height: 26px;
      fill: var(--brand-arctic-ice);
      filter: drop-shadow(0 0 4px rgba(224, 242, 254, 0.2));
    }

    .nav-logo-text {
      font-family: var(--font-primary);
      font-weight: 700;
      font-size: 1.45rem;
      color: var(--brand-orange);
      letter-spacing: -0.02em;
    }

    .nav-back-link {
      color: var(--gray-velocity);
      text-decoration: none;
      font-family: var(--font-secondary);
      font-weight: 500;
      font-size: 0.9rem;
      transition: var(--transition-fast);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-back-link:hover {
      color: var(--brand-orange);
    }

    /* Main Container */
    main {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 3rem 2rem;
    }

    .form-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      width: 100%;
      max-width: 620px;
      padding: 3rem;
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.5);
      position: relative;
    }

    .form-header {
      margin-bottom: 2.25rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1.5rem;
    }

    .form-free-badge {
      font-family: var(--font-technical);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--brand-orange);
      background: rgba(255, 160, 40, 0.08);
      border: 1px solid rgba(255, 160, 40, 0.25);
      padding: 6px 14px;
      border-radius: 4px;
      display: inline-block;
      margin-bottom: 1.25rem;
      font-weight: 700;
    }

    .form-title {
      font-family: var(--font-primary);
      font-size: 2rem;
      font-weight: 700;
      color: var(--white-horizon);
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }

    .form-desc {
      font-family: var(--font-secondary);
      font-size: 0.95rem;
      color: var(--gray-velocity);
      line-height: 1.5;
    }

    /* Form Fields */
    .form-group {
      margin-bottom: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .form-label {
      font-family: var(--font-secondary);
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--white-horizon);
    }

    .form-input {
      background: #040a1b;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--white-horizon);
      padding: 0.8rem 1rem;
      font-family: var(--font-body);
      font-size: 0.95rem;
      transition: var(--transition-fast);
      width: 100%;
    }

    .form-input:focus {
      outline: none;
      border-color: var(--brand-orange);
      box-shadow: 0 0 10px rgba(255, 160, 40, 0.15);
    }

    .btn-submit {
      background: var(--brand-orange);
      color: var(--brand-deep-slate);
      border: none;
      padding: 1rem 2rem;
      border-radius: 8px;
      font-family: var(--font-secondary);
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      box-shadow: 0 4px 15px rgba(255, 160, 40, 0.3);
      transition: var(--transition-normal);
      width: 100%;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-top: 1rem;
    }

    .btn-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 22px rgba(255, 160, 40, 0.45);
    }

    /* Success Card States */
    .success-container {
      display: none;
      text-align: center;
      padding: 1rem 0;
    }

    .success-icon {
      width: 64px;
      height: 64px;
      fill: var(--success);
      margin: 0 auto 1.5rem;
      filter: drop-shadow(0 0 10px rgba(16, 185, 129, 0.3));
    }

    .success-subtitle {
      font-family: var(--font-technical);
      font-size: 0.75rem;
      color: var(--brand-orange);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 0.75rem;
      font-weight: 700;
    }

    .success-desc {
      font-size: 0.95rem;
      color: var(--gray-velocity);
      margin-bottom: 2rem;
      line-height: 1.6;
    }

    .console-box {
      background: #040a1b;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
      text-align: left;
      font-family: var(--font-technical);
      font-size: 0.75rem;
      color: var(--gray-velocity);
      max-height: 200px;
      overflow-y: auto;
      margin-bottom: 2rem;
      line-height: 1.5;
    }

    .console-line {
      margin-bottom: 6px;
    }

    .console-label {
      color: var(--brand-orange);
      font-weight: 700;
    }

    .console-green {
      color: var(--success);
    }

    /* Technical Footer */
    footer {
      border-top: 1px solid var(--border-color);
      background-color: rgba(8, 20, 49, 0.8);
      padding: 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.8rem;
      color: var(--gray-velocity);
    }

    .footer-log {
      font-family: var(--font-technical);
      color: var(--brand-orange);
    }

    @media (max-width: 968px) {
      nav {
        padding: 0 2.5rem;
      }
    }

    @media (max-width: 640px) {
      .form-card {
        padding: 2rem;
      }
      nav {
        padding: 0 2rem;
      }
      footer {
        flex-direction: column;
        gap: 12px;
        text-align: center;
      }
    }

    @media (max-width: 480px) {
      nav {
        padding: 0 1.25rem;
      }
      .form-card {
        padding: 1.5rem 1.25rem;
      }
      .form-title {
        font-size: 1.6rem;
      }
      .nav-back-link span {
        display: none;
      }
    }
  </style>
</head>
<body>

  <!-- Navigation -->
  <nav>
    <a href="website.html" class="nav-logo">
      <svg class="nav-logo-svg" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M215.091 262.074C225.098 242.154 233.069 222.999 238 205C128 150 36 108 18 92C100 72 240 82 318 125C362 95 396 63 410 50C400 78 348 125 310 178C387.357 273.608 453.711 349.930 463.471 371.947C421.845 360.891 320.138 335.704 215.091 262.074Z"/>
      </svg>
      <span class="nav-logo-text">Birdverse</span>
    </a>
    
    <a href="website.html" class="nav-back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      <span>Back to Homepage</span>
    </a>
  </nav>

  <!-- Main Section -->
  <main>
    <div class="form-card">
      
      <!-- Inquiry Form Container -->
      <div id="inquiry-form-container">
        <div class="form-header">
          <div class="form-free-badge">Talk to Us</div>
          <h1 class="form-title">Inquiry</h1>
          <p class="form-desc">Send a message to our team. We would love to hear from you and discuss the possibilities.</p>
        </div>

        <form id="inquiry-form" onsubmit="handleInquirySubmit(event)">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
            <div class="form-group" style="margin-bottom: 0;">
              <label class="form-label" for="first-name">First Name</label>
              <input class="form-input" type="text" id="first-name" required placeholder="e.g. Ross" />
            </div>
            <div class="form-group" style="margin-bottom: 0;">
              <label class="form-label" for="last-name">Last Name</label>
              <input class="form-input" type="text" id="last-name" required placeholder="e.g. Martinez" />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="email">Email Address</label>
            <input class="form-input" type="email" id="email" required placeholder="e.g. rmartinez@apexflight.com" />
          </div>

          <div class="form-group">
            <label class="form-label" for="message">Message</label>
            <textarea class="form-input" id="message" required rows="5" placeholder="Please let us know how we can help you." style="resize: vertical; font-family: var(--font-body);"></textarea>
          </div>

          <button class="btn-submit" type="submit">Submit</button>
        </form>
      </div>

      <!-- Success Container -->
      <div class="success-container" id="success-container">
        <svg class="success-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        <div class="success-subtitle">inquiry packet queued</div>
        <h2 class="form-title" style="margin-bottom: 1rem;">Inquiry Dispatched</h2>
        
        <p class="success-desc">
          Your inquiry has been processed. We've logged the transaction telemetry below and pre-packaged an email packet for <strong>fly@birdverse.ai</strong>.
        </p>

        <div class="console-box" id="console-logs">
          <!-- Populated by JS -->
        </div>

        <a href="website.html" class="btn-submit" style="display: block; text-decoration: none; margin-top: 2rem;">Return to Homepage</a>
      </div>

    </div>
  </main>

  <!-- Technical Footer -->
  <footer>
    <div>
      &copy; 2026 Birdverse. All rights reserved.
    </div>
    <div class="footer-log">
      SYS GATEWAY: ONLINE // SMTP RELAY ACTIVE // fly@birdverse.ai
    </div>
  </footer>

  <script is:inline>
    function handleInquirySubmit(e) {
      e.preventDefault();
      
      const firstName = document.getElementById('first-name').value;
      const lastName = document.getElementById('last-name').value;
      const name = `${firstName} ${lastName}`;
      const email = document.getElementById('email').value;
      const subject = "Birdverse Inquiry";
      const message = document.getElementById('message').value;

      // Hide form
      document.getElementById('inquiry-form-container').style.display = 'none';
      
      // Show success container
      const successBox = document.getElementById('success-container');
      successBox.style.display = 'block';

      // Build simulated console logs
      const consoleBox = document.getElementById('console-logs');
      consoleBox.innerHTML = '';

      const logs = [
        `[INGEST] Resolving inquiry details for sender: ${name}`,
        `[INGEST] Sender Email: ${email}`,
        `[ENCODE] Packing payload: subject="${subject}"`,
        `[ROUTE] Connecting to outbound SMTP relay for: fly@birdverse.ai`,
        `[CRYPT] Computing secure checksum for transmission verification...`,
        `[SUCCESS] Checksum verified. Handshake completed.`,
        `[REDIRECT] Launching local mail composer to dispatch directly...`,
        `[STATUS] <span class="console-green">SUCCESS: Email compose window opened. Inquiry sent to manual review backlog.</span>`
      ];

      logs.forEach((log, index) => {
        setTimeout(() => {
          const div = document.createElement('div');
          div.className = 'console-line';
          div.innerHTML = `<span class="console-label">&gt;</span> ${log}`;
          consoleBox.appendChild(div);
          consoleBox.scrollTop = consoleBox.scrollHeight;
        }, index * 300);
      });

      // Prepare mailto composition
      const mailtoUrl = `mailto:fly@birdverse.ai?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent("Sender Name: " + name + "\nSender Email: " + email + "\n\nMessage:\n" + message)}`;
      
      // Delay mailto opening slightly so the user can see the logs beginning to write
      setTimeout(() => {
        window.location.href = mailtoUrl;
      }, 1000);
    }
  </script>

</body>
</html>

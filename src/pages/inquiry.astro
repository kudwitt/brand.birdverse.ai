---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Birdverse — Talk to Us</title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Montserrat:wght@700;800&family=Outfit:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  
  <style>
    :root {
      /* Typography */
      --font-primary: 'Montserrat', sans-serif;
      --font-secondary: 'Outfit', sans-serif;
      --font-body: 'Inter', sans-serif;
      --font-technical: 'JetBrains Mono', monospace;

      /* Color Tokens (Cockpit Standard) */
      --dark-bg: #081431;            /* Aether Blue */
      --card-bg: #101e3e;            /* Deep Cockpit Surface */
      --card-bg-hover: #17284f;      /* Sleek Hover Blue */
      
      --brand-orange: #ffa028;       /* Terminal Orange */
      --brand-arctic-ice: #e0f2fe;   /* Arctic Ice */
      --brand-deep-slate: #0f172a;   /* Deep Slate */
      
      --gray-velocity: #c1cbd4;      /* Velocity Gray */
      --white-horizon: #f7f9fb;      /* Horizon White */

      /* Avionics Status Alerts */
      --success: hsl(145, 80%, 45%);   /* Avionics Green */
      --caution: hsl(40, 100%, 50%);   /* Aviation Amber */
      --alert: hsl(350, 100%, 45%);     /* Master Warning Red */

      --border-color: rgba(224, 242, 254, 0.08);
      --border-glow: rgba(255, 160, 40, 0.25);
      
      --transition-normal: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      --transition-fast: all 0.15s ease;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html, body {
      max-width: 100vw;
      overflow-x: hidden;
      width: 100%;
    }

    body {
      background-color: var(--dark-bg);
      color: var(--white-horizon);
      font-family: var(--font-body);
      line-height: 1.6;
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    /* Background Gradients */
    body::before {
      content: '';
      position: absolute;
      top: -10%;
      left: -15%;
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, rgba(255, 160, 40, 0.04) 0%, rgba(8, 20, 49, 0) 70%);
      z-index: -1;
      pointer-events: none;
    }

    body::after {
      content: '';
      position: absolute;
      bottom: -10%;
      right: -10%;
      width: 700px;
      height: 700px;
      background: radial-gradient(circle, rgba(224, 242, 254, 0.03) 0%, rgba(8, 20, 49, 0) 70%);
      z-index: -1;
      pointer-events: none;
    }

    /* Fixed Navigation Bar */
    nav {
      width: 100%;
      height: 75px;
      background: rgba(8, 20, 49, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-color);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 4rem;
      z-index: 1000;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .nav-logo-svg {
      width: 26px;
      height: 26px;
      fill: var(--brand-arctic-ice);
      filter: drop-shadow(0 0 4px rgba(224, 242, 254, 0.2));
    }

    .nav-logo-text {
      font-family: var(--font-primary);
      font-weight: 700;
      font-size: 1.45rem;
      color: var(--brand-orange);
      letter-spacing: -0.02em;
    }

    .nav-back-link {
      color: var(--brand-orange);
      background: rgba(255, 160, 40, 0.08);
      border: 1px solid rgba(255, 160, 40, 0.25);
      border-radius: 20px;
      padding: 0.5rem 1.1rem;
      text-decoration: none;
      font-family: var(--font-secondary);
      font-weight: 600;
      font-size: 0.95rem;
      transition: var(--transition-normal);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .nav-back-link:hover {
      background: var(--brand-orange);
      color: var(--brand-deep-slate);
      box-shadow: 0 0 12px var(--border-glow);
    }

    /* Main Container */
    main {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 3rem 2rem;
    }

    .form-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      width: 100%;
      max-width: 620px;
      padding: 3rem;
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.5);
      position: relative;
    }

    .form-header {
      margin-bottom: 2.25rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1.5rem;
    }

    .form-free-badge {
      font-family: var(--font-technical);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--brand-orange);
      background: rgba(255, 160, 40, 0.08);
      border: 1px solid rgba(255, 160, 40, 0.25);
      padding: 6px 14px;
      border-radius: 4px;
      display: inline-block;
      margin-bottom: 1.25rem;
      font-weight: 700;
      text-wrap: balance;
      max-width: 100%;
    }

    .form-title {
      font-family: var(--font-primary);
      font-size: 2rem;
      font-weight: 700;
      color: var(--white-horizon);
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }

    .form-desc {
      font-family: var(--font-secondary);
      font-size: 0.95rem;
      color: var(--gray-velocity);
      line-height: 1.5;
      text-wrap: balance;
    }

    /* Form Fields */
    .form-group {
      margin-bottom: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .form-label {
      font-family: var(--font-secondary);
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--white-horizon);
    }

    .form-input {
      background: #040a1b;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--white-horizon);
      padding: 0.8rem 1rem;
      font-family: var(--font-body);
      font-size: 0.95rem;
      transition: var(--transition-fast);
      width: 100%;
    }

    .form-input:focus {
      outline: none;
      border-color: var(--brand-orange);
      box-shadow: 0 0 10px rgba(255, 160, 40, 0.15);
    }

    .btn-submit {
      background: var(--brand-orange);
      color: var(--brand-deep-slate);
      border: none;
      padding: 1rem 2rem;
      border-radius: 8px;
      font-family: var(--font-secondary);
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      box-shadow: 0 4px 15px rgba(255, 160, 40, 0.3);
      transition: var(--transition-normal);
      width: 100%;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-top: 1rem;
    }

    .btn-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 22px rgba(255, 160, 40, 0.45);
    }

    .btn-secondary {
      background: rgba(224, 242, 254, 0.03);
      border: 1px solid var(--border-color);
      color: var(--white-horizon) !important;
      padding: 0.95rem 2.5rem;
      border-radius: 8px;
      font-family: var(--font-secondary);
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      transition: var(--transition-normal);
      text-decoration: none;
      display: block;
      text-align: center;
      width: 100%;
      box-sizing: border-box;
    }

    .btn-secondary:hover {
      background: rgba(224, 242, 254, 0.08);
      border-color: var(--gray-velocity);
      color: var(--brand-orange) !important;
      transform: translateY(-2px);
    }

    /* Success Card States */
    .success-container {
      display: none;
      text-align: center;
      padding: 1rem 0;
    }

    .success-icon {
      width: 64px;
      height: 64px;
      fill: var(--success);
      margin: 0 auto 1.5rem;
      filter: drop-shadow(0 0 10px rgba(16, 185, 129, 0.3));
    }

    .success-subtitle {
      font-family: var(--font-technical);
      font-size: 0.75rem;
      color: var(--brand-orange);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 0.75rem;
      font-weight: 700;
    }

    .success-desc {
      font-size: 0.95rem;
      color: var(--gray-velocity);
      margin-bottom: 2rem;
      line-height: 1.6;
    }

    .console-box {
      background: #040a1b;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
      text-align: left;
      font-family: var(--font-technical);
      font-size: 0.75rem;
      color: var(--gray-velocity);
      max-height: 200px;
      overflow-y: auto;
      margin-bottom: 2rem;
      line-height: 1.5;
    }

    .console-line {
      margin-bottom: 6px;
    }

    .console-label {
      color: var(--brand-orange);
      font-weight: 700;
    }

    .console-green {
      color: var(--success);
    }

    /* Technical Footer */
    footer {
      border-top: 1px solid var(--border-color);
      background-color: rgba(8, 20, 49, 0.8);
      padding: 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.8rem;
      color: var(--gray-velocity);
    }

    .footer-log {
      font-family: var(--font-technical);
      color: var(--brand-orange);
    }

    @media (max-width: 968px) {
      nav {
        padding: 0 2.5rem;
      }
    }

    @media (max-width: 640px) {
      .form-card {
        padding: 2rem;
      }
      nav {
        padding: 0 2rem;
      }
      footer {
        flex-direction: column;
        gap: 12px;
        text-align: center;
      }
    }

    @media (max-width: 480px) {
      nav {
        padding: 0 1.25rem;
      }
      .form-card {
        padding: 1.5rem 1.25rem;
      }
      .form-title {
        font-size: 1.6rem;
      }
    }
  </style>
</head>
<body>

  <!-- Navigation -->
  <nav>
    <a href="index.html" class="nav-logo">
      <svg class="nav-logo-svg" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M215.091 262.074C225.098 242.154 233.069 222.999 238 205C128 150 36 108 18 92C100 72 240 82 318 125C362 95 396 63 410 50C400 78 348 125 310 178C387.357 273.608 453.711 349.930 463.471 371.947C421.845 360.891 320.138 335.704 215.091 262.074Z"/>
      </svg>
      <span class="nav-logo-text">Birdverse</span>
    </a>
    
    <a href="index.html" class="nav-back-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      <span>Back</span>
    </a>
  </nav>

  <!-- Main Section -->
  <main>
    <div class="form-card">
      
      <!-- Inquiry Form Container -->
      <div id="inquiry-form-container">
        <div class="form-header">
          <div class="form-free-badge">Talk to Us</div>
          <h1 class="form-title">Inquiry</h1>
          <p class="form-desc">Send a message to our team. We would love to hear from you and discuss the possibilities.</p>
        </div>

        <form id="inquiry-form" onsubmit="handleInquirySubmit(event)">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
            <div class="form-group" style="margin-bottom: 0;">
              <label class="form-label" for="first-name">First Name</label>
              <input class="form-input" type="text" id="first-name" required placeholder="e.g. Ross" />
            </div>
            <div class="form-group" style="margin-bottom: 0;">
              <label class="form-label" for="last-name">Last Name</label>
              <input class="form-input" type="text" id="last-name" required placeholder="e.g. Martinez" />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="email">Professional Email</label>
            <input class="form-input" type="email" id="email" required placeholder="e.g. rmartinez@apexflight.com" />
          </div>

          <div class="form-group">
            <label class="form-label" for="message">Message</label>
            <textarea class="form-input" id="message" required rows="5" placeholder="Please let us know how we can help you." style="resize: vertical; font-family: var(--font-body);"></textarea>
          </div>

          <button class="btn-submit" type="submit">Submit</button>
        </form>
      </div>

      <!-- Success Container -->
      <div class="success-container" id="success-container">
        <svg class="success-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        <div class="success-subtitle">inquiry packet queued</div>
        <h2 class="form-title" style="margin-bottom: 1rem;">Inquiry Dispatched</h2>
        
        <p class="success-desc">
          Your inquiry has been processed. We've logged the transaction telemetry below.
        </p>

        <div class="console-box" id="console-logs">
          <!-- Populated by JS -->
        </div>

        <a href="#" id="mailto-cta" class="btn-submit" style="display: none; text-decoration: none; margin-top: 2rem; margin-bottom: 1rem; text-align: center;">Compose Email Manually</a>
        <a href="index.html" class="btn-secondary" style="margin-top: 2rem;">Return to Homepage</a>
      </div>

    </div>
  </main>

  

  <script is:inline>
    async function handleInquirySubmit(e) {
      e.preventDefault();
      
      const firstName = document.getElementById('first-name').value;
      const lastName = document.getElementById('last-name').value;
      const name = `${firstName} ${lastName}`;
      const email = document.getElementById('email').value;
      const message = document.getElementById('message').value;

      // Hide form
      document.getElementById('inquiry-form-container').style.display = 'none';
      
      // Show success container
      const successBox = document.getElementById('success-container');
      successBox.style.display = 'block';

      // Build simulated console logs
      const consoleBox = document.getElementById('console-logs');
      consoleBox.innerHTML = '';

      const addLog = (log) => {
        const div = document.createElement('div');
        div.className = 'console-line';
        div.innerHTML = `<span class="console-label">&gt;</span> ${log}`;
        consoleBox.appendChild(div);
        consoleBox.scrollTop = consoleBox.scrollHeight;
      };

      addLog(`[INGEST] Resolving inquiry details for sender: ${name}`);
      addLog(`[INGEST] Sender Email: ${email}`);
      addLog(`[API] Dispatching secure POST request to API...`);

      // Determine API endpoint based on hostname
      const host = window.location.hostname;
      let apiEndpoint = 'https://api.birdverse.ai/api/inquiry';
      
      if (host === 'localhost' || host === '127.0.0.1') {
        apiEndpoint = 'http://localhost:3001/api/inquiry';
      }

      try {
        const response = await fetch(apiEndpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            name,
            email,
            message
          })
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || 'API request failed');
        }

        addLog(`[API] <span class="console-green">SUCCESS: Inquiry logged.</span>`);
        addLog(`[ENCODE] Packing payload: subject="Birdverse Inquiry"`);
        addLog(`[ROUTE] Outbound email dispatched via Resend to fly@birdverse.ai`);
        addLog(`[STATUS] <span class="console-green">SUCCESS: Inquiry queued for manual review backlog.</span>`);

      } catch (err) {
        addLog(`[API] <span class="text-danger" style="color: var(--alert);">ERROR: Failed to submit inquiry to backend API.</span>`);
        addLog(`[API] Details: ${err.message}`);
        addLog(`[API] <span class="console-label">FALLBACK:</span> Initiating manual email dispatch fallback...`);

        // Setup manual fallback button
        const mailtoUrl = `mailto:fly@birdverse.ai?subject=${encodeURIComponent("Birdverse Inquiry")}&body=${encodeURIComponent("Sender Name: " + name + "\nSender Email: " + email + "\n\nMessage:\n" + message)}`;
        const mailtoBtn = document.getElementById('mailto-cta');
        if (mailtoBtn) {
          mailtoBtn.setAttribute('href', mailtoUrl);
          mailtoBtn.style.display = 'block';
        }
      }
    }
  </script>

</body>
</html>

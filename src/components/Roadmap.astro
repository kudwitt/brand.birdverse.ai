---
interface RoadmapPhase {
  days: string;
  phase: string;
  title: string;
  items: string[];
}

interface Props {
  pretitle?: string;
  title?: string;
  desc?: string;
  phases?: RoadmapPhase[];
}

const {
  pretitle = "GTM Execution",
  title = "60-Day Execution Roadmap",
  desc = "Our targeted founder-led rollout plan to recruit strategic partners and secure industry liquidity.",
  phases = [
    {
      days: "1-15",
      phase: "Phase 01",
      title: "OEM Alignment",
      items: [
        "Pitch Daher & Pilatus C-suite on SB distribution channels.",
        "Secure commitments from 2 key strategic engine manufacturers."
      ]
    },
    {
      days: "16-30",
      phase: "Phase 02",
      title: "MRO Onboarding",
      items: [
        "Secure beta trials with Duncan Aviation & StandardAero teams.",
        "Integrate E-sign & Escrow release APIs for Part 145 invoices."
      ]
    },
    {
      days: "31-45",
      phase: "Phase 03",
      title: "Fleet Integration",
      items: [
        "Onboard NetJets & Flexjet pilot and crew communication loops.",
        "Run live tests on automated AD compliance check alerts."
      ]
    },
    {
      days: "46-60",
      phase: "Phase 04",
      title: "Platform Liquidity",
      items: [
        "Go-live on first $10M escrow fuel & service transaction releases.",
        "Activate public discovery listings & reputation scores."
      ]
    }
  ]
} = Astro.props;
---

<section class="roadmap" id="roadmap">
  <div class="section-header">
    <span class="section-pretitle">{pretitle}</span>
    <h2 class="section-title">{title}</h2>
    <p class="section-desc">{desc}</p>
  </div>
  
  <div class="roadmap-timeline">
    {phases.map(item => (
      <div class="roadmap-card">
        <div class="roadmap-indicator">{item.days}</div>
        <div class="roadmap-phase">{item.phase}</div>
        <div class="roadmap-heading">{item.title}</div>
        <ul class="roadmap-list">
          {item.items.map(bullet => (
            <li class="roadmap-item">
              <span class="roadmap-bullet">▪</span> {bullet}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

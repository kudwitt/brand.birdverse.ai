---
interface Props {
  pretitle?: string;
  title?: string;
  desc?: string;
}

const {
  pretitle = "Live Telemetry",
  title = "Telemetry Terminal Live Monitor",
  desc = "Simulate live technical dispatch loops, airworthiness agents, and escrow release telemetry."
} = Astro.props;
---

<section class="simulator" id="simulator">
  <div class="section-header">
    <span class="section-pretitle">{pretitle}</span>
    <h2 class="section-title">{title}</h2>
    <p class="section-desc">{desc}</p>
  </div>
  
  <div class="sim-box">
    <div class="sim-header">
      <div class="sim-tabs">
        <button class="sim-tab active" id="btn-sim-ad_sdr" onclick="loadSimOutput('ad_sdr')">ADs & SDRs</button>
        <button class="sim-tab" id="btn-sim-valuations" onclick="loadSimOutput('valuations')">Aircraft Valuations</button>
        <button class="sim-tab" id="btn-sim-rfq" onclick="loadSimOutput('rfq')">One-Click RFQs</button>
      </div>
      <div class="sim-telemetry-text">
        <div class="sim-telemetry-dot"></div>
        <span id="sim-telemetry-status">FAA AD/SDR FEED: STREAMING</span>
      </div>
    </div>
    
    <div class="sim-viewport" id="sim-console-output">
      <!-- Rendered via JS -->
    </div>
  </div>
</section>

<script is:inline>
  // Initialize the console feed when component loads on page
  if (typeof window.loadSimOutput === 'function') {
    window.loadSimOutput('ad_sdr');
  } else {
    // Fallback if window function is not defined immediately
    document.addEventListener('DOMContentLoaded', () => {
      if (typeof window.loadSimOutput === 'function') {
        window.loadSimOutput('ad_sdr');
      }
    });
  }
</script>

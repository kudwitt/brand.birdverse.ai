---
interface Props {
  pretitle?: string;
  title?: string;
  desc?: string;
}

const {
  pretitle = "Measurable ROI",
  title = "Tailored Value Propositions",
  desc = "Delivering operational gains and financial assurances across all core aviation stakeholders."
} = Astro.props;
---

<section class="roi-pitches" id="roi">
  <div class="roi-container">
    <div class="section-header">
      <span class="section-pretitle">{pretitle}</span>
      <h2 class="section-title">{title}</h2>
      <p class="section-desc">{desc}</p>
    </div>

    <div class="roi-tabs">
      <button class="roi-tab-btn active" data-tab="fleet">Fleet Owners & Operators</button>
      <button class="roi-tab-btn" data-tab="mro">Tier-1 Part 145 MROs</button>
      <button class="roi-tab-btn" data-tab="oem">OEMs & Parts Manufacturers</button>
    </div>

    <!-- Tab 1: Fleet Owners & Operators -->
    <div class="roi-content-box" id="roi-content-fleet">
      <div>
        <div>
          <h4 class="roi-column-title">Measurable ROI</h4>
          <ul class="roi-list">
            <li class="roi-item">
              <span class="roi-marker">✓</span>
              <span class="roi-text"><strong>Paperless AOG & Scheduled RFQs:</strong> Send service requests to multiple vetted MROs instantly. Save up to 40 hours of manual dispatch phone calls.</span>
            </li>
            <li class="roi-item">
              <span class="roi-marker">✓</span>
              <span class="roi-text"><strong>Escrow Shield Protection:</strong> Lock funds securely in escrow. Payments are released only when the work is signed off and compliance checks pass.</span>
            </li>
            <li class="roi-item">
              <span class="roi-marker">✓</span>
              <span class="roi-text"><strong>Real-time FAA & News Sync:</strong> Stay updated on FAA airworthiness directives and tail registries automatically.</span>
            </li>
          </ul>
        </div>
        <div style="margin-top: 3rem;">
          <h4 class="roi-column-title">Target Specific Pitch</h4>
          <ul class="roi-list">
            <li class="roi-item">
              <span class="roi-marker">▪</span>
              <span class="roi-text"><strong>Absolute Fleet Visibility:</strong> Complete oversight of active valuations and en-route flight milestones.</span>
            </li>
            <li class="roi-item">
              <span class="roi-marker">▪</span>
              <span class="roi-text"><strong>End Email Chains:</strong> Single workspace replacing fragmented communication networks.</span>
            </li>
          </ul>
        </div>
      </div>
      <div>
        <h4 class="roi-column-title">High-Trust Ecosystem Recruits</h4>
        <div class="targets-list-grid">
          <div class="target-tag">NetJets Aviation</div>
          <div class="target-tag">Flexjet</div>
          <div class="target-tag">Wheels Up Operations</div>
          <div class="target-tag">Solairus Aviation</div>
          <div class="target-tag">Executive Jet Management</div>
          <div class="target-tag">Clay Lacy Aviation</div>
          <div class="target-tag">Jet Linx Aviation</div>
          <div class="target-tag">Tradewind Aviation</div>
        </div>
      </div>
    </div>

    <!-- Tab 2: Tier-1 MROs -->
    <div class="roi-content-box" id="roi-content-mro" style="display: none;">
      <div>
        <div>
          <h4 class="roi-column-title">Measurable ROI</h4>
          <ul class="roi-list">
            <li class="roi-item">
              <span class="roi-marker">✓</span>
              <span class="roi-text"><strong>Eliminate Bad Debts:</strong> Escrow guarantees funding is secured before you turn a wrench. Never get left holding the bag.</span>
            </li>
            <li class="roi-item">
              <span class="roi-marker">✓</span>
              <span class="roi-text"><strong>Accelerate Cash Flow:</strong> Milestone-based payments automatically release funds to your bank upon digital e-sign.</span>
            </li>
            <li class="roi-item">
              <span class="roi-marker">✓</span>
              <span class="roi-text"><strong>Structured Customer Chat:</strong> Keep communication organized in context of the tail and work order.</span>
            </li>
          </ul>
        </div>
        <div style="margin-top: 3rem;">
          <h4 class="roi-column-title">Target Specific Pitch</h4>
          <ul class="roi-list">
            <li class="roi-item">
              <span class="roi-marker">▪</span>
              <span class="roi-text"><strong>Reduce Administrative Overhead:</strong> Fast digital sign-offs and invoices eliminate hours of AR chasing.</span>
            </li>
            <li class="roi-item">
              <span class="roi-marker">▪</span>
              <span class="roi-text"><strong>Expand Customer Awareness:</strong> Capture business from new fleet operators through our discovery index.</span>
            </li>
          </ul>
        </div>
      </div>
      <div>
        <h4 class="roi-column-title">High-Trust Ecosystem Recruits</h4>
        <div class="targets-list-grid">
          <div class="target-tag">West Star Aviation</div>
          <div class="target-tag">Duncan Aviation</div>
          <div class="target-tag">StandardAero</div>
          <div class="target-tag">Jet Aviation</div>
          <div class="target-tag">FEAM Aero</div>
          <div class="target-tag">Constant Aviation</div>
          <div class="target-tag">AAR Corp</div>
          <div class="target-tag">Lufthansa Technik</div>
        </div>
      </div>
    </div>

    <!-- Tab 3: OEMs -->
    <div class="roi-content-box" id="roi-content-oem" style="display: none;">
      <div>
        <div>
          <h4 class="roi-column-title">Measurable ROI</h4>
          <ul class="roi-list">
            <li class="roi-item">
              <span class="roi-marker">✓</span>
              <span class="roi-text"><strong>Notice Distribution Channel:</strong> Broadcast Service Bulletins, Airworthiness Directives, and manuals directly to owners.</span>
            </li>
            <li class="roi-item">
              <span class="roi-marker">✓</span>
              <span class="roi-text"><strong>Manual Rental Storefront:</strong> Sell operational manuals by the project directly to MROs in context.</span>
            </li>
            <li class="roi-item">
              <span class="roi-marker">✓</span>
              <span class="roi-text"><strong>Streamlined Warranties:</strong> Manage warranty logs and recall issues directly with operators.</span>
            </li>
          </ul>
        </div>
        <div style="margin-top: 3rem;">
          <h4 class="roi-column-title">Target Specific Pitch</h4>
          <ul class="roi-list">
            <li class="roi-item">
              <span class="roi-marker">▪</span>
              <span class="roi-text"><strong>Raise New Product Awareness:</strong> Target new product announcements directly to verified owners.</span>
            </li>
            <li class="roi-item">
              <span class="roi-marker">▪</span>
              <span class="roi-text"><strong>Improve Warranty Communications:</strong> Connect directly to resolve issues and increase brand loyalty.</span>
            </li>
          </ul>
        </div>
      </div>
      <div>
        <h4 class="roi-column-title">High-Trust Ecosystem Recruits</h4>
        <div class="targets-list-grid">
          <div class="target-tag">Daher</div>
          <div class="target-tag">Pilatus</div>
          <div class="target-tag">Gulfstream Aerospace</div>
          <div class="target-tag">Textron Aviation</div>
          <div class="target-tag">Bombardier</div>
          <div class="target-tag">Pratt & Whitney</div>
          <div class="target-tag">Honeywell Aerospace</div>
          <div class="target-tag">Collins Aerospace</div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.roi-tab-btn');
  const contentBoxes = document.querySelectorAll('.roi-content-box');

  buttons.forEach(button => {
    button.addEventListener('click', () => {
      buttons.forEach(btn => btn.classList.remove('active'));
      button.classList.add('active');

      const targetTab = button.getAttribute('data-tab');
      contentBoxes.forEach(box => {
        if (box.id === `roi-content-${targetTab}`) {
          (box as HTMLElement).style.display = 'grid';
        } else {
          (box as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

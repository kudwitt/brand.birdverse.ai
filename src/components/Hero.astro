---
interface Props {
  badge?: string;
  title?: string;
  tagline?: string;
  url?: string;
  desc?: string;
  primaryCtaText?: string;
  primaryCtaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  ctaSubtext?: string;
}

const {
  badge = "60-Day Founder-Led GTM Plan",
  title = "Birdverse",
  tagline = "The Terminal for Global Aviation.",
  url = "birdverse.ai",
  desc = "Defragment your operations, communication, and payments. One unified desktop for Fleet Operators, MROs, and OEMs. Stop losing Hobbs hours to manual RFQs, disconnected PDFs, and payment friction. Welcome to the industry's single source of truth.",
  primaryCtaText = "Scan Your Tail (Free Valuation)",
  primaryCtaLink = "#valuation",
  secondaryCtaText = "Talk to an Aviation Specialist →",
  secondaryCtaLink = "join.html",
  ctaSubtext = "No subscriptions. No onboarding fees. Only a 1% escrow fee, paid by the Seller, to keep Birdverse free."
} = Astro.props;
---

<section class="hero">
  {badge && <div class="hero-gtm-badge">{badge}</div>}
  <h1 class="hero-title">{title}</h1>
  {tagline && <div class="hero-tagline">{tagline}</div>}
  {url && <div class="hero-url">{url}</div>}
  {desc && <p class="hero-gtm-desc" set:html={desc}></p>}
  
  <div class="cta-container">
    <div class="cta-group">
      <a href={primaryCtaLink} class="btn-primary">{primaryCtaText}</a>
      <a href={secondaryCtaLink} class="btn-secondary">{secondaryCtaText}</a>
    </div>
    {ctaSubtext && <div class="cta-subtext" set:html={ctaSubtext}></div>}
  </div>
</section>

